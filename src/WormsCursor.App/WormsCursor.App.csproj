<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>WormsCursor.App</RootNamespace>
    <AssemblyName>WormsCursor</AssemblyName>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>Assets\Icon.ico</ApplicationIcon>
    <Version>0.8.2</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- Installer + auto-update. Pinned to the same major/build PowerLink ships
         (0.0.1298) so the vpk CLI tool and the runtime library stay in lockstep. -->
    <PackageReference Include="Velopack" Version="0.0.1298" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WormsCursor.Core\WormsCursor.Core.csproj" />
  </ItemGroup>

  <!-- Generated by tools/generate-icon.py. Copied next to the exe so the tray
       can load it at runtime via AppContext.BaseDirectory (PowerLink pattern). -->
  <ItemGroup>
    <None Update="Assets\Icon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
